# ── Server ────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── MongoDB Atlas ─────────────────────────────────────────────
# Get this from https://cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/school_management?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_min_32_chars
JWT_EXPIRE=7d

# ── Client URL (your Render app URL) ─────────────────────────
# Used for Socket.IO CORS — set to your Render service URL
CLIENT_URL=https://your-app-name.onrender.com
